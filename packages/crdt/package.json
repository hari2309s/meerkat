{
  "name": "@meerkat/crdt",
  "version": "0.2.0",
  "description": "Orchestration layer — wires @meerkat/local-store and @meerkat/p2p together. Exposes the unified den API that the app uses.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "yjs": "^13.0.0"
  },
  "dependencies": {
    "@meerkat/local-store": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "fake-indexeddb": "^5.0.0",
    "yjs": "^13.6.18",
    "@testing-library/react": "^14.0.0",
    "@testing-library/dom": "^9.0.0",
    "jsdom": "^22.1.0",
    "@vitejs/plugin-react": "^4.2.1"
  }
}