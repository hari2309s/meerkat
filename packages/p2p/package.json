{
  "name": "@meerkat/p2p",
  "version": "0.1.0",
  "description": "WebRTC peer connections for Meerkat visitor sessions — scoped Yjs sync, Supabase Realtime signaling, offline Letterbox drops.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@meerkat/keys": "workspace:*",
    "@meerkat/local-store": "workspace:*",
    "@meerkat/types": "workspace:*",
    "lib0": "^0.2.90",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.18"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "yjs": "^13.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@meerkat/config": "workspace:*",
    "@supabase/supabase-js": "^2.39.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "private": true,
  "type": "module",
  "license": "ISC"
}
