{
  "name": "@meerkat/burrows",
  "version": "0.1.0",
  "description": "Pages (burrows) system for Meerkat — block-based documents backed by Yjs + IndexedDB",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "license": "ISC",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yjs": "^13.6.18",
    "y-indexeddb": "^9.0.12"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@meerkat/config": "workspace:*",
    "@testing-library/dom": "^9.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "fake-indexeddb": "^5.0.0",
    "jsdom": "^22.1.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "private": true
}
